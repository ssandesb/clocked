# Copy to .env for local runs (never commit .env)
# The portal you want to automate - just the domain works too (https:// is added)
PORTAL_URL=https://founderp.ai

# Alternate deploy (needs netlify.toml SPA redirects — see README):
# PORTAL_URL=https://cockedin.netlify.app

# Login credentials (demo portal uses the same value for both)
PORTAL_EMAIL=bajracharyasandeshh@gmail.com
PORTAL_PASSWORD=bajracharyasandeshh@gmail.com

# Shift schedule - local times in the timezone below
ATTENDANCE_TZ=Asia/Kathmandu
CLOCK_IN_TIME=09:00
CLOCK_OUT_TIME=18:45

# "auto" mode matches an action when now is within this many minutes of a slot
TIME_TOLERANCE_MIN=90

# --- Calendar → GitHub clock-out trigger (calendar_clockout_trigger.py) ---
COMPOSIO_API_KEY=
# Required for Composio tool execute with a connected account (cron / API):
COMPOSIO_USER_ID=
COMPOSIO_CONNECTED_ACCOUNT_ID=
CLOCK_OUT_EVENT_TITLE=Clock Out Trigger
GITHUB_OWNER=ssandesb
GITHUB_REPO=clocked
GITHUB_WORKFLOW=attendance.yml
GITHUB_REF=main
CALENDAR_LOOKBACK_HOURS=2
CALENDAR_LOOKAHEAD_HOURS=24

# --- cron-job.org 24/7 scheduler ---
# Full walkthrough: CRON_COMPOSIO_GITHUB_SETUP.md
# API key from https://console.cron-job.org/settings -> Create API Key
CRONJOB_API_KEY=
#
# Legacy route (Netlify function router):
CRON_TRIGGER_URL=https://cockedin.netlify.app/.netlify/functions/attendance-cron
CRON_TRIGGER_SECRET=erp_attendance_cron_8f3k2m
#
# Preferred route: cron-job.org POSTs to Composio execute URL with:
#   header x-api-key = COMPOSIO_API_KEY
#   body includes user_id + connected_account_id + stringified arguments.inputs
#
# --- LinkedIn daily post (linkedin_post_bot.py) ---
# GitHub dispatch uses COMPOSIO_CONNECTED_ACCOUNT_ID (GitHub ca_…).
# The bot uses separate connected accounts for LinkedIn + Gmail tools:
COMPOSIO_LINKEDIN_CONNECTED_ACCOUNT_ID=
COMPOSIO_GMAIL_CONNECTED_ACCOUNT_ID=
LINKEDIN_WORKFLOW=linkedin-post.yml
LINKEDIN_CRON_HOUR=23
LINKEDIN_CRON_MINUTE=50
NOTIFY_EMAIL=bajracharyasandeshh@gmail.com
